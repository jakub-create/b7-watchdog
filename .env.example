# Copy to .env for local runs.  DO NOT commit .env (it holds secrets).

# --- B7 ID login ---
B7_EMAIL=tvuj@email.cz
B7_PASSWORD=tvoje-heslo

# Který závod hlídat (z URL tržiště ?raceId=...)
B7_RACE_ID=699b407072bb7f5cd634f41a

# --- E-mail sending (SMTP). Gmail example: ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvuj@gmail.com
SMTP_PASS=app-heslo-z-gmailu          # Gmail "App password", NE běžné heslo
MAIL_TO=kam-poslat@email.cz
MAIL_FROM=tvuj@gmail.com

# discovery (jednorázově, vypíše surové API) nebo watch (ostrý běh)
MODE=watch
